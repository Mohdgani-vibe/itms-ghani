# First-run checklist before any real deploy or non-dry-run sync:
# - Set POSTGRES_PASSWORD, TELEPORT_AUTH_TOKEN, and TELEPORT_CA_PIN.
# - Replace SESSION_STORAGE_URI, SESSION_STORAGE_ACCESS_KEY, SESSION_STORAGE_SECRET_KEY, and BACKUP_S3_URI.
# - Verify TLS_CERT_PATH, TLS_KEY_PATH, SALT_API_TLS_CERT_PATH, and SALT_API_TLS_KEY_PATH exist on their target hosts.
# - Run: TSH_BIN="$HOME/.local/bin/tsh" "$HOME/.local/bin/tsh" login --proxy=teleport.zerodha.internal:443

# Required before first real deploy or remote sync.
POSTGRES_PASSWORD=replace-with-openssl-rand-hex-32
TELEPORT_AUTH_TOKEN=replace-with-openssl-rand-hex-32
TELEPORT_CA_PIN=replace-after-first-start
SESSION_STORAGE_URI=s3://replace-with-secure-bucket/teleport/sessions
SESSION_STORAGE_ACCESS_KEY=replace-with-access-key
SESSION_STORAGE_SECRET_KEY=replace-with-secret-key
BACKUP_S3_URI=s3://replace-with-secure-bucket/teleport/backups

TELEPORT_IMAGE=public.ecr.aws/gravitational/teleport:16.4.8
POSTGRES_IMAGE=postgres:15.6-alpine
NGINX_IMAGE=nginx:1.27-alpine

# Public DNS names exposed to operators and managed nodes.
CLUSTER_NAME=teleport.zerodha.internal
WEB_PUBLIC_ADDR=teleport.zerodha.internal
SSH_PUBLIC_ADDR=teleport.zerodha.internal:8877
TUNNEL_PUBLIC_ADDR=teleport.zerodha.internal:3024
SALT_APP_PUBLIC_ADDR=salt-api.teleport.zerodha.internal
SALT_APP_ENVIRONMENT=replace-with-salt-app-environment

# Local bind ports on the Teleport gateway host.
WEB_LISTEN_PORT=443
SSH_LISTEN_PORT=8877
TUNNEL_LISTEN_PORT=3024

# TLS material presented by Nginx for the web UI.
TLS_CERT_PATH=/etc/ssl/private/teleport/fullchain.pem
TLS_KEY_PATH=/etc/ssl/private/teleport/privkey.pem

# PostgreSQL credentials used by Teleport auth/proxy nodes.
POSTGRES_DB=teleport
POSTGRES_USER=teleport

# Teleport bootstrap values.
TELEPORT_LICENSE_PATH=/etc/teleport/license.pem

# Session and event storage. Prefer S3 in production; NFS is the fallback.
SESSION_STORAGE_TYPE=s3
SESSION_STORAGE_REGION=ap-south-1
SESSION_STORAGE_ENDPOINT=

# Salt API endpoint protected behind Teleport Application Access.
SALT_API_URI=http://salt-api.internal.zerodha.local:8000
SALT_API_HEALTHCHECK_PATH=/run
SALT_API_SKIP_VERIFY=false
SALT_API_BIND_HOST=10.10.30.20
SALT_API_BIND_PORT=8000
SALT_API_TLS_CERT_PATH=/etc/pki/salt-api/tls.crt
SALT_API_TLS_KEY_PATH=/etc/pki/salt-api/tls.key
SALT_API_CONFIG_TARGET=/etc/salt/master.d/rest_cherrypy.conf
SALT_API_SERVICE_NAME=salt-api
SALT_API_HEALTHCHECK_URL=https://127.0.0.1:8000/run
SALT_API_HEALTHCHECK_TIMEOUT=10
SALT_API_JOURNAL_LINES=50
SALT_API_SSH_TRANSPORT=direct
SALT_API_SSH_HOST=salt-api.internal.zerodha.local
SALT_API_SSH_PORT=22
SALT_API_SSH_USER=root
SALT_API_REMOTE_TMPDIR=/tmp
SALT_API_SSH_OPTIONS=
SALT_API_TELEPORT_PROXY=teleport.zerodha.internal:443
SALT_API_TELEPORT_CLUSTER=
SALT_API_TELEPORT_NODE=
SALT_API_TELEPORT_OPTIONS=

# Local PAM accounts on the salt-api host that Teleport-approved users map to.
SALT_PAM_GROUP_PRODUCTION=saltops-prod
SALT_PAM_GROUP_STAGING=saltops-staging
SALT_PAM_GROUP_MONITORING=saltops-monitoring

# Backup targets.
BACKUP_ROOT=/var/backups/teleport
NFS_BACKUP_TARGET=/mnt/teleport-backups

# Monitoring and syslog forwarding.
PROMETHEUS_EXTERNAL_LABEL=teleport-prod
SYSLOG_TARGET=10.10.20.50
SYSLOG_PORT=514
