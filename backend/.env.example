SSH_TERMINAL_KNOWN_HOSTS_PATH=
SSH_TERMINAL_HOST_OVERRIDES=
# Example: SSH_TERMINAL_HOST_OVERRIDES=spare=ubuntu@10.10.60.121:8877
SSH_TERMINAL_STRICT_HOST_KEY=true
